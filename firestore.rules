rules_version = '2';

// Reglas de seguridad de Firestore para TOP FUT.
// Idea: los VISITANTES (sin login) solo pueden LEER la agenda/partidos e
// incrementar contadores de estadísticas. Todo lo que administra el panel
// (crear/editar/borrar partidos, streams, publicar la agenda, config) requiere
// estar AUTENTICADO (el login del panel usa Firebase Auth email/contraseña).
//
// Cómo aplicarlas: consola de Firebase → Firestore Database → pestaña "Reglas"
// → pega TODO esto → Publicar.

service cloud.firestore {
  match /databases/{database}/documents {

    // Agenda pública que leen el index y el reproductor.
    // Solo el panel autenticado la publica.
    match /public/schedule {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contadores de estadísticas: los visitantes (sin login) los incrementan.
    // Lectura pública (el panel los grafica). NOTA: al ser escritura abierta,
    // alguien podría inflar los números; el impacto es bajo (solo métricas).
    match /public/stats {
      allow read: if true;
      allow write: if true;
    }

    // Presencia de espectadores (contador "👁 viendo" del reproductor).
    // Cada espectador escribe SOLO su doc con un timestamp; el conteo se hace
    // con consultas de agregación count(). Escritura abierta pero con datos
    // mínimos (solo el campo 't'); impacto bajo, igual que /public/stats.
    match /presence/{slug}/v/{vid} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['t']);
      allow delete: if true;
    }

    // Partidos: lectura pública (respaldo del cliente). Escritura solo el panel.
    match /matches/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Streams guardados: solo el panel (el cliente no los usa).
    match /streams/{id} {
      allow read, write: if request.auth != null;
    }

    // Enlaces "legacy": el reproductor aún los lee como respaldo.
    match /generatedLinks/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config: la URL del proxy no es sensible (lectura pública para el panel);
    // el resto de config, cerrado a autenticados.
    match /config/importer {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /config/{id} {
      allow read, write: if request.auth != null;
    }

    // Todo lo demás: cerrado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
